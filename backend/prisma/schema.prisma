// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  password           String
  nombre             String?        @default("Usuario")
  rol                String         @default("ESTUDIANTE") // "PROFESOR", "ESTUDIANTE", "SUPERADMIN"
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  // Relations
  refreshTokens      RefreshToken[]
  perfilProfesor     Profesor?
  asignaciones       Asignacion[]
  cursoId            Int?
  curso              Curso?         @relation(fields: [cursoId], references: [id])
  charlasOrganizadas Charla[]       @relation("OrganizadorCharlas")
  charlasAsiste      Charla[]       @relation("ParticipantesCharlas")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Profesor {
  id           Int      @id @default(autoincrement())
  especialidad String
  biografia    String?
  
  userId       String   @unique
  usuario      User     @relation(fields: [userId], references: [id])
}

model Curso {
  id           Int          @id @default(autoincrement())
  nombre       String       // Ej: "6to 4ta"
  estudiantes  User[]
  asignaciones Asignacion[]
}

model Materia {
  id           Int          @id @default(autoincrement())
  nombre       String       // Ej: "Programación"
  asignaciones Asignacion[]
}

model Aula {
  id           Int          @id @default(autoincrement())
  nombre       String       // Ej: "Laboratorio 1"
  piso         Int
  asignaciones Asignacion[]
  charlas      Charla[]
}

model Asignacion {
  id          Int      @id @default(autoincrement())
  diaSemana   String   // Ej: "Lunes"
  horaInicio  String   // Ej: "07:30"
  horaFin     String   // Ej: "12:00"

  profesorId  String
  profesor    User     @relation(fields: [profesorId], references: [id])

  cursoId     Int
  curso       Curso    @relation(fields: [cursoId], references: [id])

  materiaId   Int
  materia     Materia  @relation(fields: [materiaId], references: [id])

  aulaId      Int
  aula        Aula     @relation(fields: [aulaId], references: [id])
}

model Charla {
  id            Int          @id @default(autoincrement())
  titulo        String       // Ej: "Introducción a la IA"
  descripcion   String?
  capacidadMax  Int          // El dato distinto que pediste
  fechaHora     DateTime     // Cuándo ocurre la charla

  aulaId        Int
  aula          Aula         @relation(fields: [aulaId], references: [id])

  organizadorId String
  organizador   User         @relation("OrganizadorCharlas", fields: [organizadorId], references: [id])

  participantes User[]       @relation("ParticipantesCharlas")
}
