# Copiar a .env (no subir al servidor; el profe ya configuró el .env allí)
DATABASE_URL="file:./dev.db"
PORT=3001

# Solo en ~/servicios/.env del servidor (agregar con nano):
# USE_API_PREFIX=false

# Al subir al servidor, copiar también prisma.config.ts a ~/servicios/ (junto a package.json)

# Opcional en local (el código tiene valores por defecto)
# JWT_ACCESS_SECRET=at-secret
# JWT_REFRESH_SECRET=rt-secret
